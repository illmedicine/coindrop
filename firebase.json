{
  "hosting": {
    "site": "coindrop-e39de",
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      ".git/**",
      ".claude/**",
      ".vscode/**",
      ".agents/**",
      "node_modules/**",
      "android/**",
      "auth-server/**",
      "iris-podcast/**",
      "package/**",
      "voices/**",
      "CNAME",
      "package.json",
      "package-lock.json",
      "capacitor.config.json",
      "skills-lock.json",
      "android-build-config.gradle",
      "create_playstore_assets.py",
      "icon_generation.log",
      "*.md",
      "*.log",
      "*.tgz",
      "*.py",
      "*.keystore",
      "keystore.properties"
    ],
    "rewrites": [
      {
        "source": "/@**",
        "destination": "/404.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=600, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
        ]
      },
      {
        "source": ".well-known/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      }
    ]
  }
}
